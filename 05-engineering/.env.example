ANTHROPIC_API_KEY=
METACULUS_API_KEY=    # required for forecast.py (live questions) and resolve.py (resolution tracking)
FRED_API_KEY=         # required for finance corpus — free at https://fred.stlouisfed.org/docs/api/api_key.html
VOYAGE_API_KEY=       # optional — better embedding quality; falls back to OpenAI
OPENAI_API_KEY=       # optional — used if VOYAGE_API_KEY not set
DATABASE_URL=sqlite:////app/data/engine.db
CHROMA_PATH=/app/chroma
