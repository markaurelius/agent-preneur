ANTHROPIC_API_KEY=        # required — Anthropic API key
FRED_API_KEY=             # required — free at https://fred.stlouisfed.org/docs/api/api_key.html
DATABASE_URL=sqlite:////app/data/engine.db

# --- Autonomous agent ---
GITHUB_TOKEN=             # GitHub PAT with Contents: Write scope
GITHUB_REPO=              # e.g. markstoughton/agent-preneur

# --- Notifications (WhatsApp primary, ntfy fallback) ---
WHATSAPP_TO=              # your number e.g. +12125551234  (read by the Baileys bridge)
NTFY_TOPIC=               # fallback — secret slug, subscribe at ntfy.sh/<topic>
