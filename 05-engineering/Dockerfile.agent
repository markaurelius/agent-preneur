FROM python:3.11-slim

# System deps: git + Node.js 20 (for Claude Code CLI)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Install Python dependencies
COPY pyproject.toml .
RUN uv sync --no-install-project --all-extras

# Install Claude Code CLI (global, available to all users)
RUN npm install -g @anthropic-ai/claude-code

# WhatsApp bridge (Baileys) — runs as background process in the same container.
# Rewrite SSH GitHub URLs to HTTPS so npm can fetch libsignal-node without SSH keys.
RUN printf '[url "https://github.com/"]\n\tinsteadOf = ssh://git@github.com/\n\tinsteadOf = git@github.com:\n' > /root/.gitconfig
COPY services/whatsapp/package.json /app/whatsapp/package.json
RUN cd /app/whatsapp && npm install --omit=dev --legacy-peer-deps
COPY services/whatsapp/index.js /app/whatsapp/index.js

ENV PATH="/app/.venv/bin:$PATH"

# Create non-root user — claude --dangerously-skip-permissions refuses to run as root
RUN useradd -m -u 1000 -s /bin/bash agent \
    && chown -R agent:agent /app

COPY --chown=agent:agent scripts/agent_entrypoint.sh /agent_entrypoint.sh
RUN chmod +x /agent_entrypoint.sh

USER agent
ENV HOME=/home/agent

# Auth dir under home so the agent user always owns it regardless of volume mount ordering
RUN mkdir -p /home/agent/auth

ENTRYPOINT ["/agent_entrypoint.sh"]
